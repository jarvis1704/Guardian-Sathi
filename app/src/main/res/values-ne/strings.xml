    <string name="ElderPermission_button">अनुमति दिनुहोस्</string>
    <string name="ElderPermission_1_T">ब्याट्री प्रतिबन्ध निष्क्रिय गर्नुहोस्</string>
    <string name="ElderPermission_1_S">गार्डियन साथी सधैं सक्रिय राख्नुहोस्</string>
    <string name="ElderPermission_1_R1">एन्ड्रोइडले पृष्ठभूमिमा तपाईंको सुरक्षा बन्द गर्नबाट रोक्छ। ब्याट्री सेभर हुँदा पनि खस्ने पत्ता लगाउने र स्थान काम गर्ने सुनिश्चित गर्छ।</string>
    <string name="ElderPermission_1_R2">अर्को स्क्रिनमा गार्डियन साथीलाई अवरोध बिना चल्न अनुमति दिन अनुरोध गरिनेछ। पुष्टि गर्न \"अनुमति दिनुहोस्\" ट्याप गर्नुहोस्।</string>
    <string name="ElderPermission_1_D">यसले तपाईंको ब्याट्रीमा खासै प्रभाव पार्दैन। यसले केवल एपलाई जबरजस्ती बन्द हुनबाट रोक्छ।</string>

    <string name="ElderPermission_2_T">सूचना पहुँच</string>
    <string name="ElderPermission_2_S">अन्य एपहरूमा ठगी पत्ता लगाउनुहोस्</string>
    <string name="ElderPermission_2_R1">व्हाट्सएप र SMS एपहरूका सूचनाहरू स्क्यान गरेर शंकास्पद लिङ्क र फिसिङ ढाँचाहरू पहिचान गर्छ।</string>
    <string name="ElderPermission_2_R2">अर्को स्क्रिनमा सूचीमा \"GuardianSathi\" खोज्नुहोस् र यसलाई सक्रिय गर्नुहोस्। पुष्टि पपअपमा \"अनुमति दिनुहोस्\" ट्याप गर्नुहोस्।</string>
    <string name="ElderPermission_2_D">हामी केवल ठगी ढाँचाका लागि सूचनाहरू विश्लेषण गर्छौं। तपाईंका व्यक्तिगत सन्देशहरू कहिल्यै पढिँदैन वा भण्डारण गरिँदैन।</string>

    <string name="ElderPermission_3_T">स्थान पहुँच</string>
    <string name="ElderPermission_3_S">तपाईंको सुरक्षाका लागि आवश्यक</string>
    <string name="ElderPermission_3_R1">तपाईंको संरक्षकले तपाईंको स्थान वास्तविक समयमा देख्न सक्छ।</string>
    <string name="ElderPermission_3_R2">आपतकालीन SOS र जियो-फेन्स सूचनाहरूका लागि आवश्यक।</string>
    <string name="ElderPermission_3_D">तपाईंको स्थान केवल तपाईंका विश्वसनीय संरक्षकसँग साझा गरिन्छ। हामी यसलाई अरूसँग कहिल्यै साझा गर्दैनौं।</string>

    <string name="ElderPermission_4_T">सधैं चालु स्थान</string>
    <string name="ElderPermission_4_S">एप बन्द हुँदा पनि सुरक्षा</string>
    <string name="ElderPermission_4_R1">गार्डियन साथी पृष्ठभूमिमा हुँदा पनि जियो-फेन्स चेतावनी काम गर्छ।</string>
    <string name="ElderPermission_4_R2">तपाईं सुरक्षित क्षेत्रबाट बाहिर जाँदा कुनै पनि समयमा तपाईंको संरक्षकलाई सूचना दिइन्छ।</string>
    <string name="ElderPermission_4_D">पृष्ठभूमि स्थान केवल सुरक्षा निगरानीका लागि प्रयोग हुन्छ र कहिल्यै बेचिँदैन वा साझा गरिँदैन।</string>

    <string name="ElderPermission_5_T">सूचित रहनुहोस्</string>
    <string name="ElderPermission_5_S">महत्त्वपूर्ण सूचनाहरू आवश्यक छन्</string>
    <string name="ElderPermission_5_R1">समयमै औषधि सम्झाउने र स्वास्थ्य जाँच सूचनाहरू प्राप्त गर्नुहोस्।</string>
    <string name="ElderPermission_5_R2">तपाईंको संरक्षकले तुरुन्तै तपाईंलाई जरुरी सन्देश पठाउन सक्छ।</string>
    <string name="ElderPermission_5_D">हामी केवल तपाईंको सुरक्षा र स्वास्थ्यसँग सम्बन्धित सूचनाहरू मात्र पठाउँछौं।</string>

    <string name="ElderPermission_6_T">खस्ने पत्ता लगाउने</string>
    <string name="ElderPermission_6_S">हामी तपाईंलाई चुपचाप हेरिरहेका छौं</string>
    <string name="ElderPermission_6_R1">अचानक खसेको पत्ता लगाएर तुरुन्तै तपाईंको संरक्षकलाई सूचना दिन्छ।</string>
    <string name="ElderPermission_6_R2">खसेपछि असामान्य स्थिरता पत्ता लगाउन गतिविधि ढाँचाहरू निगरानी गर्छ।</string>
    <string name="ElderPermission_6_D">गतिविधि डेटा तपाईंको उपकरणमै प्रक्रिया हुन्छ र कहिल्यै सर्भरमा अपलोड हुँदैन।</string>

    <string name="ElderPermission_7_T">SMS सुरक्षा</string>
    <string name="ElderPermission_7_S">ठगी सन्देशबाट जोगिनुहोस्</string>
    <string name="ElderPermission_7_R1">आउने सन्देशहरूलाई स्क्यान गरेर ज्ञात ठगी र फिसिङ ढाँचाहरू पत्ता लगाउँछ।</string>
    <string name="ElderPermission_7_R2">तपाईंले गल्तीले प्रतिक्रिया दिनुअघि तपाईंको संरक्षकलाई चेतावनी दिन्छ।</string>
    <string name="ElderPermission_7_D">तपाईंका सन्देशहरू तपाईंको उपकरणमै स्क्यान गरिन्छन्। हामी तपाईंका व्यक्तिगत SMS कहिल्यै पढ्दैनौं वा भण्डारण गर्दैनौं।</string>

    <string name="ElderPermission_8_T">कल सुरक्षा</string>
    <string name="ElderPermission_8_S">वास्तविक समयमा ठगी कल पत्ता लगाउनुहोस्</string>
    <string name="ElderPermission_8_R1">ज्ञात ठगी नम्बरहरूबाट आउने कलहरू पहिचान गर्छ।</string>
    <string name="ElderPermission_8_R2">शंकास्पद कल प्राप्त हुँदा तपाईंको संरक्षकलाई सूचना दिइन्छ।</string>
    <string name="ElderPermission_8_D">कल डेटा केवल ठगी पत्ता लगाउन प्रयोग हुन्छ र कहिल्यै भण्डारण वा साझा गरिँदैन।</string>

    <string name="ElderPermission_9_T">कल इतिहास पहुँच</string>
    <string name="ElderPermission_9_S">शंकास्पद कल ढाँचा पहिचान गर्नुहोस्</string>
    <string name="ElderPermission_9_R1">कल इतिहास विश्लेषण गरेर ठगी नम्बरबाट दोहोरिने सम्पर्क पत्ता लगाउँछ।</string>
    <string name="ElderPermission_9_R2">समयसँगै असामान्य कल ढाँचाहरू बुझ्न तपाईंको संरक्षकलाई सहयोग गर्छ।</string>
    <string name="ElderPermission_9_D">कल इतिहास स्थानीय रूपमा विश्लेषण गरिन्छ र केवल चिन्हित प्रविष्टिहरू मात्र साझा गरिन्छ।</string>

    <string name="ElderPermission_10_T">फुल स्क्रिन चेतावनी</string>
    <string name="ElderPermission_10_S">आपतकालीन चेतावनी तुरुन्तै हेर्नुहोस्</string>
    <string name="ElderPermission_10_R1">फोन लक भएको वा अर्को एप खुला हुँदा पनि SOS र खस्ने चेतावनी स्क्रिनमा देखाउँछ।</string>
    <string name="ElderPermission_10_R2">अर्को स्क्रिनमा \"GuardianSathi\" खोज्नुहोस् र \"Allow full screen intents\" सक्षम गर्नुहोस्।</string>
    <string name="ElderPermission_10_D">यो केवल अत्यावश्यक सुरक्षा सूचनाका लागि प्रयोग हुन्छ। कुनै विज्ञापन वा अनावश्यक पपअप देखाइँदैन।</string>

    <string name="ElderPermission_11_T">सम्पर्क पहुँच</string>
    <string name="ElderPermission_11_S">अपरिचित कलर पहिचान गर्नुहोस्</string>
    <string name="ElderPermission_11_R1">आउने र जाने कलहरूलाई तपाईंका सम्पर्कसँग मिलाएर शंकास्पद नम्बरहरू पत्ता लगाउँछ।</string>
    <string name="ElderPermission_11_R2">अपरिचित नम्बरबाट बारम्बार सम्पर्क हुँदा तपाईंको संरक्षकलाई चेतावनी दिइन्छ।</string>
    <string name="ElderPermission_11_D">सम्पर्कहरू केवल तपाईंको उपकरणमै जाँचिन्छन् र कहिल्यै अपलोड वा साझा गरिँदैन।</string>

