    <string name="LinkElder_Share_S">तपाईं सुरक्षित रूपमा उनीहरूको सुरक्षा र स्वास्थ्य अपडेटहरू निगरानी गर्न जडान हुनुहुनेछ।</string>
    <string name="LinkElder_button">अहिले जडान गर्नुहोस्</string>
    <string name="LinkElder_Cam_Per">QR कोड स्क्यान गर्न क्यामेरा पहुँच आवश्यक छ</string>
    <string name="LinkElder_Cam_Per_Button">अनुमति दिनुहोस्</string>

    <string name="ConnectionSuccess_H">सफलतापूर्वक जडान भयो</string>
    <string name="ConnectionSuccess_D">तपाईं अब यससँग जडान हुनुभयो:</string>
