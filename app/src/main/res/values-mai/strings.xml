    <string name="ElderPermission_1_T">बैटरी प्रतिबंध बंद करू</string>
    <string name="ElderPermission_1_S">GuardianSathi केँ हमेशा सक्रिय राखू</string>
    <string name="ElderPermission_1_R1">Android केँ बैकग्राउंड मे अहाँक सुरक्षा बंद करबाक सँ रोकैत अछि। बैटरी सेवर चालू रहला पर सेहो गिरबाक पहचान आ लोकेशन कार्य करैत रहत।</string>
    <string name="ElderPermission_1_R2">एकटा स्क्रीन देखाएत जे GuardianSathi केँ बिना प्रतिबंध चलाबय लेल अनुमति मांगत। पुष्टि लेल "अनुमति दिअ" दबाउ।</string>
    <string name="ElderPermission_1_D">ई अहाँक बैटरी जीवन पर खास असर नहि करैत अछि। ई केवल Android केँ ऐप जबरदस्ती बंद करबाक सँ रोकैत अछि।</string>

    <string name="ElderPermission_2_T">नोटिफिकेशन एक्सेस</string>
    <string name="ElderPermission_2_S">दोसर ऐप मे ठगी पहचानू</string>
    <string name="ElderPermission_2_R1">WhatsApp आ SMS ऐपक नोटिफिकेशन केँ संदिग्ध लिंक आ फिशिंग पैटर्न लेल स्कैन करैत अछि।</string>
    <string name="ElderPermission_2_R2">अगिला स्क्रीन मे "GuardianSathi" खोजू आ टॉगल चालू करू। पुष्टि पॉपअप पर "अनुमति दिअ" दबाउ।</string>
    <string name="ElderPermission_2_D">हम केवल ठगी पैटर्न लेल नोटिफिकेशन विश्लेषण करैत छी। अहाँक निजी संदेश नहि पढ़ल जाइत अछि आ नहि संग्रहित होइत अछि।</string>

    <string name="ElderPermission_3_T">लोकेशन एक्सेस</string>
    <string name="ElderPermission_3_S">अहाँक सुरक्षाक लेल जरूरी</string>
    <string name="ElderPermission_3_R1">अहाँक गार्डियन अहाँक लोकेशन रियल टाइम मे देख सकैत छथि।</string>
    <string name="ElderPermission_3_R2">आपातकालीन SOS आ जियो-फेंस चेतावनी लेल जरूरी।</string>
    <string name="ElderPermission_3_D">अहाँक लोकेशन केवल भरोसेमंद गार्डियन संग साझा होइत अछि। दोसर ककरो संग नहि।</string>

    <string name="ElderPermission_4_T">हमेशा चालू लोकेशन</string>
    <string name="ElderPermission_4_S">ऐप बंद होए पर सेहो सुरक्षा</string>
    <string name="ElderPermission_4_R1">GuardianSathi बैकग्राउंड मे रहला पर सेहो जियो-फेंस चेतावनी कार्य करैत अछि।</string>
    <string name="ElderPermission_4_R2">जँ अहाँ सुरक्षित क्षेत्र छोड़ैत छी तऽ गार्डियन केँ सूचना भेटत।</string>
    <string name="ElderPermission_4_D">बैकग्राउंड लोकेशन केवल सुरक्षा लेल उपयोग होइत अछि। ई नहि बेचायल जाइत अछि आ नहि साझा।</string>

